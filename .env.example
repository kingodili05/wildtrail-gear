# Resend transactional email
# Get an API key at https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=

# From-address that appears in the buyer's inbox.
# Recommended: WildTrail Gear <orders@wildtrailgear.store>
# Requires domain verification in Resend dashboard before using your own domain.
# While unverified, use the sandbox: WildTrail Gear <orders@resend.dev>
RESEND_FROM=WildTrail Gear <orders@resend.dev>

# Optional admin BCC. Every order email is copied to this address.
# Leave blank to disable.
RESEND_ADMIN_CC=
